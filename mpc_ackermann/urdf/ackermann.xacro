<?xml version="1.0"?>
<robot name="ackermann" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Propiedades generales -->
  <xacro:property name="wheel_radius" value="0.3"/>
  <xacro:property name="base_elevation" value="0.3"/>
  <xacro:property name="chassis_length" value="2.01142"/>
  <xacro:property name="chassis_width" value="1"/>
  <xacro:property name="chassis_height" value="0.568726"/>
  <xacro:arg name = "base_color" default="1.0 0.0 0.0 1.0" />
  <xacro:arg name="ns"    default="ackermann"/>

  <!-- Materiales -->
  <material name="gray">
    <color rgba="0.5 0.5 1.0 1.0"/>
  </material>

  <material name="black">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>

  <link name="$(arg ns)/base_footprint"/>

  <joint name="$(arg ns)/base_footprint_joint" type="fixed">
    <parent link="$(arg ns)/base_footprint"/>
    <child link="$(arg ns)/chassis"/>
    <origin xyz="0 0 ${base_elevation}" rpy="0 0 0"/>
  </joint>

  <!-- Chasis -->
  <link name="$(arg ns)/chassis">
    <visual>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1.14395"/>
      <inertia ixx="0.126164" ixy="0.0" ixz="0.0" iyy="0.416519" iyz="0.0" izz="0.481014"/>
    </inertial>
  </link>

  <!-- Ruedas traseras -->
  <link name="$(arg ns)/rear_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="-1.5707 0 0"/>
      <geometry>
          <cylinder length="0.15" radius="${wheel_radius}"/>
      </geometry>
      <material name="black"/>
    </visual>
      <collision>
        <origin xyz="0 0 0" rpy="-1.5707 0 0"/>
        <geometry>
          <cylinder length="0.15" radius="${wheel_radius}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0"/>
        <mass value="2"/>
        <inertia ixx="0.145833" ixy="0" ixz="0" iyy="0.145833" iyz="0" izz="0.125"/>
      </inertial>
  </link>

  <joint name="$(arg ns)/rear_left_wheel_joint" type="continuous">
    <parent link="$(arg ns)/chassis"/>
    <child link="$(arg ns)/rear_left_wheel"/>
    <origin xyz="-0.957138 0.625029 ${wheel_radius-base_elevation}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="$(arg ns)/rear_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="-1.5707 0 0"/>
      <geometry>
        <cylinder length="0.15" radius="${wheel_radius}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.5707 0 0"/>
      <geometry>
        <cylinder length="0.15" radius="${wheel_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="2"/>
      <inertia ixx="0.145833" ixy="0" ixz="0" iyy="0.145833" iyz="0" izz="0.125"/>
    </inertial>
  </link>

  <joint name="$(arg ns)/rear_right_wheel_joint" type="continuous">
    <parent link="$(arg ns)/chassis"/>
    <child link="$(arg ns)/rear_right_wheel"/>
    <origin xyz="-0.957138 -0.625029 ${wheel_radius-base_elevation}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
 

  <!-- Eslabones de dirección delanteros -->
  <link name="$(arg ns)/front_left_wheel_steering">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.1" radius="0.03"/>
      </geometry>
      <material name="black"/>
    </visual>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.0153" ixy="0.0" ixz="0.0" iyy="0.025" iyz="0.0" izz="0.0153"/>
    </inertial>
  </link>

  <joint name="$(arg ns)/front_left_wheel_steering_joint" type="revolute">
      <parent link="$(arg ns)/chassis"/>
      <child link="$(arg ns)/front_left_wheel_steering"/>
      <origin xyz="0.554283 0.5 ${wheel_radius-base_elevation}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.8" upper="0.8" effort="25" velocity="1.0"/>
  </joint>

  <link name="$(arg ns)/front_right_wheel_steering">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.1" radius="0.03"/>
      </geometry>
      <material name="black"/>
    </visual>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.0153" ixy="0.0" ixz="0.0" iyy="0.025" iyz="0.0" izz="0.0153"/>
    </inertial>
  </link>

  <joint name="$(arg ns)/front_right_wheel_steering_joint" type="revolute">
      <parent link="$(arg ns)/chassis"/>
      <child link="$(arg ns)/front_right_wheel_steering"/>
      <origin xyz="0.554283 -0.5 ${wheel_radius-base_elevation}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.8" upper="0.8" effort="25" velocity="1.0"/>
  </joint>


  <!-- Ruedas delanteras -->
  <link name="$(arg ns)/front_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="-1.5707 0 0"/>
      <geometry>
        <cylinder length="0.15" radius="${wheel_radius}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.5707 0 0"/>
      <geometry>
        <cylinder length="0.15" radius="${wheel_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="2"/>
      <inertia ixx="0.145833" ixy="0" ixz="0" iyy="0.145833" iyz="0" izz="0.125"/>
    </inertial>
  </link>

  <joint name="$(arg ns)/front_left_wheel_joint" type="continuous">
    <parent link="$(arg ns)/front_left_wheel_steering"/>
    <child link="$(arg ns)/front_left_wheel"/>
    <origin xyz="0.0 0.125029 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="$(arg ns)/front_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="-1.5707 0 0"/>
      <geometry>
        <cylinder length="0.15" radius="${wheel_radius}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.5707 0 0"/>
      <geometry>
        <cylinder length="0.15" radius="${wheel_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="2"/>
      <inertia ixx="0.145833" ixy="0" ixz="0" iyy="0.145833" iyz="0" izz="0.125"/>
    </inertial>
  </link>

  <joint name="$(arg ns)/front_right_wheel_joint" type="continuous">
    <parent link="$(arg ns)/front_right_wheel_steering"/>
    <child link="$(arg ns)/front_right_wheel"/>
    <origin xyz="0.0 -0.125029 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

   <!-- ************************ SENSORS DEFINITION ***************************** -->
  <!-- IMU -->
  <gazebo reference="$(arg ns)/chassis">
    <sensor name="imu_sensor" type="imu">
      <ignition_frame_id>$(arg ns)/chassis</ignition_frame_id>
      <always_on>1</always_on>
      <update_rate>50</update_rate>
      <visualize>false</visualize>
      <topic>$(arg ns)/imu</topic>
      <imu>
        <enable_orientation>0</enable_orientation>
        <angular_velocity>
          <x>
            <noise type="gaussian">
              <mean>0</mean>
              <stddev>0.009</stddev>
              <bias_mean>0.00075</bias_mean>
              <bias_stddev>0.005</bias_stddev>
              <dynamic_bias_stddev>0.00002</dynamic_bias_stddev>
              <dynamic_bias_correlation_time>400.0</dynamic_bias_correlation_time>
              <precision>0.00025</precision>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0</mean>
              <stddev>0.009</stddev>
              <bias_mean>0.00075</bias_mean>
              <bias_stddev>0.005</bias_stddev>
              <dynamic_bias_stddev>0.00002</dynamic_bias_stddev>
              <dynamic_bias_correlation_time>400.0</dynamic_bias_correlation_time>
              <precision>0.00025</precision>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0</mean>
              <stddev>0.009</stddev>
              <bias_mean>0.00075</bias_mean>
              <bias_stddev>0.005</bias_stddev>
              <dynamic_bias_stddev>0.00002</dynamic_bias_stddev>
              <dynamic_bias_correlation_time>400.0</dynamic_bias_correlation_time>
              <precision>0.00025</precision>
            </noise>
          </z>
        </angular_velocity>
        <linear_acceleration>
          <x>
            <noise type="gaussian">
              <mean>0</mean>
              <stddev>0.021</stddev>
              <bias_mean>0.05</bias_mean>
              <bias_stddev>0.0075</bias_stddev>
              <dynamic_bias_stddev>0.000375</dynamic_bias_stddev>
              <dynamic_bias_correlation_time>175.0</dynamic_bias_correlation_time>
              <precision>0.005</precision>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0</mean>
              <stddev>0.021</stddev>
              <bias_mean>0.05</bias_mean>
              <bias_stddev>0.0075</bias_stddev>
              <dynamic_bias_stddev>0.000375</dynamic_bias_stddev>
              <dynamic_bias_correlation_time>175.0</dynamic_bias_correlation_time>
              <precision>0.005</precision>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0</mean>
              <stddev>0.021</stddev>
              <bias_mean>0.05</bias_mean>
              <bias_stddev>0.0075</bias_stddev>
              <dynamic_bias_stddev>0.000375</dynamic_bias_stddev>
              <dynamic_bias_correlation_time>175.0</dynamic_bias_correlation_time>
              <precision>0.005</precision>
            </noise>
          </z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>



  <gazebo>
    <plugin
      filename="ignition-gazebo-ackermann-steering-system"
      name="gz::sim::systems::AckermannSteering">
      <left_joint>$(arg ns)/rear_left_wheel_joint</left_joint>
      <right_joint>$(arg ns)/rear_right_wheel_joint</right_joint>
      <left_steering_joint>$(arg ns)/front_left_wheel_steering_joint</left_steering_joint>
      <right_steering_joint>$(arg ns)/front_right_wheel_steering_joint</right_steering_joint>
      <kingpin_width>1.0</kingpin_width>
      <steering_limit>2.0</steering_limit>
      <wheel_base>1.511421</wheel_base>
      <wheel_separation>1.25</wheel_separation>
      <wheel_radius>0.3</wheel_radius>
      <min_velocity>-10</min_velocity>
      <max_velocity>10</max_velocity>
      <min_acceleration>-10</min_acceleration>
      <max_acceleration>10</max_acceleration>
      <odom_frame>$(arg ns)/odom</odom_frame>           <!-- ← Agregar -->
      <robot_base_frame>base_footprint</robot_base_frame>  <!-- ← Agregar -->
      <publish_odom_tf>true</publish_odom_tf >
    </plugin>


    <plugin
        filename="gz-sim-joint-state-publisher-system"
        name = "gz::sim::systems::JointStatePublisher">
    </plugin>
  </gazebo>

</robot>